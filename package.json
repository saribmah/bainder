{
  "name": "{{APP_NAME}}",
  "version": "0.0.0",
  "private": true,
  "description": "{{DESCRIPTION}}",
  "workspaces": {
    "packages": [
      "packages/api",
      "packages/sdk",
      "packages/web"
    ]
  },
  "scripts": {
    "build": "bun run --workspaces --if-present build",
    "lint": "bun run --workspaces --if-present lint",
    "lint:fix": "bun run --workspaces --if-present lint:fix",
    "format": "oxfmt --check --no-error-on-unmatched-pattern \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "format:fix": "oxfmt --write --no-error-on-unmatched-pattern \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "ts-check": "bun run --workspaces --if-present ts-check",
    "test": "bun run --workspaces --if-present test",
    "tsgo:version": "tsgo --version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260226.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0"
  },
  "lint-staged": {
    "packages/**/*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix --quiet",
      "oxfmt --write"
    ]
  },
  "packageManager": "bun@1.3.10"
}
