# Loaded by Vite when running `vite build` (mode = "production").
# Values here are public — they ship inside the bundle. Do NOT put secrets.
#
# Split-domain deploy: the Worker serves the SPA on baindar.com and the API on
# api.baindar.com. Keep these aligned with packages/api/wrangler.jsonc.
VITE_API_URL=https://api.baindar.com
VITE_AUTH_URL=https://api.baindar.com/auth
