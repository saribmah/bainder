{
  "name": "@bainder/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --no-env-file run vite --port 3002",
    "build": "bunx --bun tsgo && bun --no-env-file run vite build",
    "preview": "bun --no-env-file run vite preview --port 3002",
    "lint": "oxlint --quiet src vite.config.ts",
    "lint:fix": "oxlint --fix --quiet src vite.config.ts",
    "format": "oxfmt --check --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./vite.config.ts\"",
    "format:fix": "oxfmt --write --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./vite.config.ts\"",
    "ts-check": "bunx --bun tsgo --noEmit"
  },
  "dependencies": {
    "@bainder/sdk": "*",
    "@bainder/ui": "workspace:*",
    "better-auth": "^1.6.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "postcss": "^8.5.8",
    "rolldown-vite": "^7.3.1",
    "tailwindcss": "^4.2.1",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
