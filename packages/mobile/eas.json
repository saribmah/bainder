{
  "cli": {
    "version": ">= 18.9.1",
    "requireCommit": true,
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "bun": "1.3.10",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.baindar.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "bun": "1.3.10",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.baindar.com"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "bun": "1.3.10",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.baindar.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
