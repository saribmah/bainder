{
  "name": "@bainder/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "oxlint --quiet src app",
    "lint:fix": "oxlint --fix --quiet src app",
    "format": "oxfmt --check --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./app/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "format:fix": "oxfmt --write --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./app/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "ts-check": "bunx --bun tsgo --noEmit"
  },
  "dependencies": {
    "@bainder/sdk": "*",
    "@bainder/ui": "workspace:*",
    "@better-auth/expo": "^1.6.9",
    "@expo/metro-runtime": "~6.1.2",
    "better-auth": "^1.6.9",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.8",
    "expo-linking": "~8.0.8",
    "expo-network": "~8.0.7",
    "expo-router": "~6.0.13",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.13.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.4",
    "typescript": "~5.9.2"
  }
}
