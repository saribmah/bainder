exports[`FloatingToolbar renders 6 buttons in light theme 1`] = `"<div role="toolbar" class="bd-floating-toolbar"><button type="button" class="bd-floating-toolbar-btn" aria-label="Copy"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="8" y="8" width="12" height="12" rx="2"></rect><path d="M16 8V5a1 1 0 00-1-1H5a1 1 0 00-1 1v10a1 1 0 001 1h3"></path></svg></button><button type="button" class="bd-floating-toolbar-btn" aria-label="Highlight"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 4l6 6-9 9-3 1-1-3z"></path><path d="M5 21h14"></path></svg></button><button type="button" class="bd-floating-toolbar-btn" aria-label="Ask Bainder"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.8 4.7L18.5 9.5 13.8 11.3 12 16l-1.8-4.7L5.5 9.5l4.7-1.8z"></path><path d="M19 16l.7 1.8L21.5 18.5l-1.8.7L19 21l-.7-1.8L16.5 18.5l1.8-.7z"></path></svg></button><button type="button" class="bd-floating-toolbar-btn" aria-label="Bookmark"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12v18l-6-4-6 4z"></path></svg></button><button type="button" class="bd-floating-toolbar-btn" aria-label="Note"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 4h11l3 3v13H5z"></path><path d="M9 10h6M9 14h6M9 18h4"></path></svg></button><button type="button" class="bd-floating-toolbar-btn" aria-label="Share"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="12" r="2.2"></circle><circle cx="18" cy="6" r="2.2"></circle><circle cx="18" cy="18" r="2.2"></circle><path d="M8 11l8-4M8 13l8 4"></path></svg></button></div>"`;

exports[`FloatingToolbar inside dark ThemeProvider 1`] = `"<div data-theme="dark"><div role="toolbar" class="bd-floating-toolbar"><button type="button" class="bd-floating-toolbar-btn" aria-label="Type"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 7V5h14v2M9 19h6M12 5v14"></path></svg></button><button type="button" class="bd-floating-toolbar-btn" aria-label="Settings"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.7 1.7 0 00.3 1.8l.1.1a2 2 0 11-2.8 2.8l-.1-.1a1.7 1.7 0 00-1.8-.3 1.7 1.7 0 00-1 1.5V21a2 2 0 11-4 0v-.1a1.7 1.7 0 00-1-1.5 1.7 1.7 0 00-1.8.3l-.1.1a2 2 0 11-2.8-2.8l.1-.1a1.7 1.7 0 00.3-1.8 1.7 1.7 0 00-1.5-1H3a2 2 0 010-4h.1a1.7 1.7 0 001.5-1 1.7 1.7 0 00-.3-1.8l-.1-.1a2 2 0 112.8-2.8l.1.1a1.7 1.7 0 001.8.3H9a1.7 1.7 0 001-1.5V3a2 2 0 014 0v.1a1.7 1.7 0 001 1.5 1.7 1.7 0 001.8-.3l.1-.1a2 2 0 112.8 2.8l-.1.1a1.7 1.7 0 00-.3 1.8V9a1.7 1.7 0 001.5 1H21a2 2 0 010 4h-.1a1.7 1.7 0 00-1.5 1z"></path></svg></button></div></div>"`;

exports[`Sheet with handle (default) 1`] = `"<div class="bd-sheet"><div aria-hidden="true" class="bd-sheet-handle"></div>content</div>"`;

exports[`Sheet without handle 1`] = `"<div class="bd-sheet">content</div>"`;

exports[`AISheet — empty state renders header + title + suggestion chips + input 1`] = `"<div class="bd-sheet"><div aria-hidden="true" class="bd-sheet-handle"></div><div class="bd-ai-header"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.8 4.7L18.5 9.5 13.8 11.3 12 16l-1.8-4.7L5.5 9.5l4.7-1.8z"></path><path d="M19 16l.7 1.8L21.5 18.5l-1.8.7L19 21l-.7-1.8L16.5 18.5l1.8-.7z"></path></svg><span class="bd-ai-header-label">Ask Bainder</span></div><h3 style="font-family:var(--font-display);font-size:17px;font-weight:500;margin:0">What does this passage mean?</h3><div class="bd-ai-input"><input type="text" placeholder="Ask anything…"/><button type="button" aria-label="Send" class="bd-ai-input-send"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12l16-8-6 16-2-7z"></path></svg></button></div></div>"`;

exports[`AISheet — thinking state quote + thinking dots + status 1`] = `"<div class="bd-sheet"><div aria-hidden="true" class="bd-sheet-handle"></div><div class="bd-ai-header"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.8 4.7L18.5 9.5 13.8 11.3 12 16l-1.8-4.7L5.5 9.5l4.7-1.8z"></path><path d="M19 16l.7 1.8L21.5 18.5l-1.8.7L19 21l-.7-1.8L16.5 18.5l1.8-.7z"></path></svg><span class="bd-ai-header-label">Bainder</span></div><blockquote class="bd-ai-quote">&quot;Affordances define what actions are possible…&quot;</blockquote><div role="status" aria-live="polite" class="bd-thinking"><span aria-hidden="true" class="bd-thinking-dot"></span><span aria-hidden="true" class="bd-thinking-dot bd-thinking-dot-2"></span><span aria-hidden="true" class="bd-thinking-dot bd-thinking-dot-3"></span><span class="bd-thinking-status">Reading the chapter…</span></div></div>"`;

exports[`AISheet — answer state quote + answer body 1`] = `"<div class="bd-sheet"><div aria-hidden="true" class="bd-sheet-handle"></div><div class="bd-ai-header"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.8 4.7L18.5 9.5 13.8 11.3 12 16l-1.8-4.7L5.5 9.5l4.7-1.8z"></path><path d="M19 16l.7 1.8L21.5 18.5l-1.8.7L19 21l-.7-1.8L16.5 18.5l1.8-.7z"></path></svg><span class="bd-ai-header-label">Bainder</span></div><blockquote class="bd-ai-quote">&quot;Affordances define what actions are possible…&quot;</blockquote><p style="font-family:var(--font-reading);font-size:12px;line-height:1.55;margin:0">Norman is drawing a careful line: an <em>affordance</em> is the relationship between an object and a person — what can be done. A <em>signifier</em> is the visible cue that tells you so.</p></div>"`;

exports[`AISheetInput disabled send 1`] = `"<div class="bd-ai-input"><input type="text" placeholder="Ask anything…" readOnly="" value=""/><button type="button" aria-label="Send" disabled="" class="bd-ai-input-send"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12l16-8-6 16-2-7z"></path></svg></button></div>"`;

exports[`AISheetThinking without status 1`] = `"<div role="status" aria-live="polite" class="bd-thinking"><span aria-hidden="true" class="bd-thinking-dot"></span><span aria-hidden="true" class="bd-thinking-dot bd-thinking-dot-2"></span><span aria-hidden="true" class="bd-thinking-dot bd-thinking-dot-3"></span></div>"`;
