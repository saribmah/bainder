// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`Wordmark renders default mark 1`] = `"<span class="bd-wordmark" style="display:inline-block;margin:0;font-family:var(--font-display);font-size:22px;font-weight:400;line-height:1;letter-spacing:-0.04em;font-variation-settings:&quot;opsz&quot; 144, &quot;SOFT&quot; 30;color:var(--bd-fg)">bainder</span>"`;

exports[`Wordmark renders as heading with custom color 1`] = `"<h1 class="bd-wordmark" style="display:inline-block;margin:0;font-family:var(--font-display);font-size:56px;font-weight:400;line-height:1;letter-spacing:-0.04em;font-variation-settings:&quot;opsz&quot; 144, &quot;SOFT&quot; 30;color:var(--paper-50)">bainder</h1>"`;

exports[`Monogram renders default mark 1`] = `"<div role="img" aria-label="Bainder" class="bd-monogram" style="width:44px;height:44px;border-radius:12px;background:var(--bd-action);display:inline-flex;align-items:center;justify-content:center;color:var(--bd-action-fg)"><span aria-hidden="true" style="font-family:var(--font-display);font-size:28px;font-weight:400;line-height:1;font-variation-settings:&quot;opsz&quot; 144, &quot;SOFT&quot; 100;color:currentColor">b</span></div>"`;

exports[`BrandLockup renders horizontal lockup 1`] = `"<div role="img" aria-label="Bainder" class="bd-brand-lockup" style="display:inline-flex;flex-direction:row;align-items:center;gap:8px"><div role="img" aria-label="Bainder" class="bd-monogram" style="width:32px;height:32px;border-radius:8px;background:var(--bd-action);display:inline-flex;align-items:center;justify-content:center;color:var(--bd-action-fg)" aria-hidden="true"><span aria-hidden="true" style="font-family:var(--font-display);font-size:20px;font-weight:400;line-height:1;font-variation-settings:&quot;opsz&quot; 144, &quot;SOFT&quot; 100;color:currentColor">b</span></div><span class="bd-wordmark" aria-hidden="true" style="display:inline-block;margin:0;font-family:var(--font-display);font-size:18px;font-weight:400;line-height:1;letter-spacing:-0.035em;font-variation-settings:&quot;opsz&quot; 144, &quot;SOFT&quot; 30;color:var(--bd-fg)">bainder</span></div>"`;

exports[`BrandLockup renders stacked lockup 1`] = `"<div role="img" aria-label="Bainder" class="bd-brand-lockup" style="display:inline-flex;flex-direction:column;align-items:center;gap:10px"><div role="img" aria-label="Bainder" class="bd-monogram" style="width:44px;height:44px;border-radius:12px;background:var(--bd-action);display:inline-flex;align-items:center;justify-content:center;color:var(--bd-action-fg)" aria-hidden="true"><span aria-hidden="true" style="font-family:var(--font-display);font-size:28px;font-weight:400;line-height:1;font-variation-settings:&quot;opsz&quot; 144, &quot;SOFT&quot; 100;color:currentColor">b</span></div><span class="bd-wordmark" aria-hidden="true" style="display:inline-block;margin:0;font-family:var(--font-display);font-size:22px;font-weight:400;line-height:1;letter-spacing:-0.04em;font-variation-settings:&quot;opsz&quot; 144, &quot;SOFT&quot; 30;color:var(--bd-fg)">bainder</span></div>"`;
