{
  "name": "@bainder/ui",
  "version": "0.0.0",
  "description": "Bainder design system — tokens, primitives, and reader components for web and React Native",
  "private": true,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./icons": {
      "types": "./src/icons/index.ts",
      "default": "./src/icons/index.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "default": "./src/primitives/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "default": "./src/theme/index.ts"
    },
    "./reader": {
      "types": "./src/reader/index.ts",
      "default": "./src/reader/index.ts"
    },
    "./styles.css": "./src/styles/index.css",
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/typography.css": "./src/styles/typography.css",
    "./styles/primitives.css": "./src/styles/primitives.css",
    "./styles/reset.css": "./src/styles/reset.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/reader.css": "./src/styles/reader.css"
  },
  "scripts": {
    "build": "bun scripts/build-tokens.ts",
    "build:tokens": "bun scripts/build-tokens.ts",
    "test": "bun test",
    "lint": "oxlint ./src ./scripts",
    "lint:fix": "oxlint --fix --quiet ./src ./scripts",
    "format": "oxfmt --check --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./scripts/**/*.{js,ts}\"",
    "format:fix": "oxfmt --write --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./scripts/**/*.{js,ts}\"",
    "ts-check": "bunx --bun tsgo --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
