{
  "name": "@baindar/ui",
  "version": "0.0.0",
  "description": "Baindar design system — tokens, primitives, and reader components for web and React Native",
  "private": true,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "react-native": {
        "types": "./src/index.native.ts",
        "default": "./src/index.native.ts"
      },
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./brand": {
      "react-native": {
        "types": "./src/brand/index.native.ts",
        "default": "./src/brand/index.native.ts"
      },
      "types": "./src/brand/index.ts",
      "default": "./src/brand/index.ts"
    },
    "./icons": {
      "react-native": {
        "types": "./src/icons/index.native.ts",
        "default": "./src/icons/index.native.ts"
      },
      "types": "./src/icons/index.ts",
      "default": "./src/icons/index.ts"
    },
    "./primitives": {
      "react-native": {
        "types": "./src/primitives/index.native.ts",
        "default": "./src/primitives/index.native.ts"
      },
      "types": "./src/primitives/index.ts",
      "default": "./src/primitives/index.ts"
    },
    "./theme": {
      "react-native": {
        "types": "./src/theme/index.native.ts",
        "default": "./src/theme/index.native.ts"
      },
      "types": "./src/theme/index.ts",
      "default": "./src/theme/index.ts"
    },
    "./reader": {
      "react-native": {
        "types": "./src/reader/index.native.ts",
        "default": "./src/reader/index.native.ts"
      },
      "types": "./src/reader/index.ts",
      "default": "./src/reader/index.ts"
    },
    "./styles.css": "./src/styles/index.css",
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/typography.css": "./src/styles/typography.css",
    "./styles/primitives.css": "./src/styles/primitives.css",
    "./styles/reset.css": "./src/styles/reset.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/reader.css": "./src/styles/reader.css"
  },
  "scripts": {
    "build": "bun scripts/build-tokens.ts",
    "build:tokens": "bun scripts/build-tokens.ts",
    "test": "bun test",
    "lint": "oxlint ./src ./scripts",
    "lint:fix": "oxlint --fix --quiet ./src ./scripts",
    "format": "oxfmt --check --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./scripts/**/*.{js,ts}\"",
    "format:fix": "oxfmt --write --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./scripts/**/*.{js,ts}\"",
    "ts-check": "bunx --bun tsgo --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": ">=0.74.0",
    "react-native-svg": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
