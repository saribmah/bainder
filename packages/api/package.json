{
  "name": "@baindar/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "dev": "wrangler dev --env dev",
    "dev:test": "wrangler dev --env dev --var TEST_MODE:true",
    "build": "bunx --bun tsgo",
    "deploy": "bun run --filter @baindar/web build && wrangler deploy --env production",
    "openapi:generate": "bun run ./scripts/generate-openapi.ts",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate:local": "bunx --bun wrangler d1 migrations apply baindar-dev --local --env dev",
    "db:migrate:dev": "bunx --bun wrangler d1 migrations apply baindar-dev --remote --env dev",
    "db:migrate": "bunx --bun wrangler d1 migrations apply baindar --remote --env production",
    "db:reset:local": "bun run ./scripts/reset-local-db.ts",
    "ts-check": "tsgo --noEmit -p tsconfig.json",
    "lint": "oxlint ./src",
    "lint:fix": "oxlint --fix --quiet ./src",
    "format": "oxfmt --check --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "format:fix": "oxfmt --write --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@better-auth/expo": "^1.6.9",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.7.2",
    "fflate": "^0.8.2",
    "hono": "^4.10.4",
    "hono-openapi": "^1.2.0",
    "node-html-parser": "^7.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/bun": "^1.3.9",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.69.0"
  }
}
