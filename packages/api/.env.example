# Copy to `.env` for local development.
# `wrangler dev` reads this file; do not commit secrets.

# Required: signs Better Auth session cookies.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# Public origin Better Auth issues redirects/cookies for. Match the URL the
# browser hits the API at. Locally that's the wrangler dev port.
BETTER_AUTH_URL=http://localhost:8787

# Optional: Google OAuth. Leave empty to disable the provider.
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Apple Sign In. Client secret is a JWT signed with your Apple
# private key — generate it externally (Better Auth treats it as a string).
# https://developer.apple.com/account/resources/services
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Optional: From-address used by the Cloudflare send_email binding for
# outbound OTP emails. Must be on a domain you've onboarded under
# Cloudflare → Email Service → Email Sending. Leave empty in local dev to
# print OTPs to the Worker logs instead.
EMAIL_FROM=
