{
	// `worker-configuration.d.ts` is generated by `bun run cf-typegen`.
	// Edit this file (not the generated d.ts), then re-run cf-typegen.
	"$schema": "node_modules/wrangler/config-schema.json",
	"compatibility_flags": ["nodejs_compat"],
	"compatibility_date": "2026-05-01",
	"name": "baindar",
	"main": "src/index.ts",
	"env": {
		"dev": {
			"name": "baindar-dev",
			"vars": {
				"API_PUBLIC_HOST": "",
				"WEB_PUBLIC_HOST": "",
				"WORKER_URL": "http://localhost:8787",
				"BETTER_AUTH_URL": "http://localhost:8787",
				"TRUSTED_ORIGINS": "http://localhost:3002,http://localhost:3003",
				"EMAIL_FROM": "",
				// Default off; the `dev:test` script overrides via
				// `wrangler dev --var TEST_MODE:true`. Production never sets this.
				"TEST_MODE": "false",
				// Chat agent model. Empty `ANTHROPIC_BASE_URL` falls back to the
				// `@ai-sdk/anthropic` default (the official API). Override per env
				// to point at a proxy or alternative provider.
				"ANTHROPIC_BASE_URL": "https://opencode.ai/zen/go/v1",
				"ANTHROPIC_MODEL": "minimax-m2.7",
				// Local sandbox mounts use the Worker R2 binding directly.
				"SANDBOX_R2_LOCAL": "true",
				"SANDBOX_R2_BUCKET_NAME": "BUCKET"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "baindar-dev",
					"database_id": "00000000-0000-0000-0000-000000000000",
					"migrations_dir": "migrations"
				}
			],
			"r2_buckets": [
				{
					"binding": "BUCKET",
					"bucket_name": "baindar-assets-dev"
				}
			],
			"ai": {
				"binding": "AI"
			},
			"send_email": [{ "name": "EMAIL" }],
			"workflows": [
				{
					"binding": "EPUB_PROCESSOR",
					"name": "baindar-epub-processor-dev",
					"class_name": "EpubWorkflow"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "ChatAgent",
						"class_name": "ChatAgent"
					},
					{
						"name": "Sandbox",
						"class_name": "Sandbox"
					}
				]
			},
			// Per-user containerised sandbox that backs the chat agent's
			// runBash tool. Each instance is one Linux container; the
			// Sandbox class lives in the @cloudflare/sandbox package and is
			// re-exported from src/index.ts. Local `wrangler dev` builds and
			// runs this image via Docker (must be running locally).
			"containers": [
				{
					"class_name": "Sandbox",
					"image": "./Dockerfile",
					"instance_type": "lite",
					"max_instances": 1
				}
			],
			// v1 created CounterAgent (smoke test). v2 retires it and stands
			// up the real ChatAgent. v3 stands up the Sandbox container DO.
			// Migrations are append-only, so retired classes are removed via
			// `deleted_classes` rather than editing earlier tags.
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["CounterAgent"]
				},
				{
					"tag": "v2",
					"deleted_classes": ["CounterAgent"],
					"new_sqlite_classes": ["ChatAgent"]
				},
				{
					"tag": "v3",
					"new_sqlite_classes": ["Sandbox"]
				}
			],
			"secrets": {
				"required": [
					"BETTER_AUTH_SECRET",
					"GOOGLE_CLIENT_ID",
					"GOOGLE_CLIENT_SECRET",
					"APPLE_CLIENT_ID",
					"APPLE_CLIENT_SECRET",
					"ANTHROPIC_API_KEY"
				]
			}
		},
		"production": {
			"workers_dev": false,
			"routes": [
				{ "pattern": "baindar.com", "custom_domain": true },
				{ "pattern": "api.baindar.com", "custom_domain": true }
			],
			"assets": {
				// Serves the built web frontend as static assets at the root domain.
				// Delete this block if you removed packages/web during init.
				"directory": "../web/dist",
				"binding": "ASSETS",
				"not_found_handling": "single-page-application",
				"run_worker_first": true
			},
			"observability": {
				"enabled": true
			},
			"vars": {
				"API_PUBLIC_HOST": "https://api.baindar.com",
				"WEB_PUBLIC_HOST": "https://baindar.com",
				"WORKER_URL": "https://api.baindar.com",
				"BETTER_AUTH_URL": "https://api.baindar.com",
				"TRUSTED_ORIGINS": "https://baindar.com,baindar-desktop://",
				"EMAIL_FROM": "no-reply@baindar.com",
				// Production keeps TEST_MODE off. The flag is part of the env
				// shape so `Config.isTestMode()` type-checks against both envs.
				"TEST_MODE": "false",
				// Chat agent model. Empty `ANTHROPIC_BASE_URL` uses the SDK's
				// default (the official Anthropic API).
				"ANTHROPIC_BASE_URL": "https://opencode.ai/zen/go/v1",
				"ANTHROPIC_MODEL": "minimax-m2.7",
				// Production sandbox mounts use R2's S3-compatible endpoint.
				"SANDBOX_R2_LOCAL": "false",
				"SANDBOX_R2_BUCKET_NAME": "baindar-assets"
			},
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "baindar",
					"database_id": "487eb50a-46f9-4f36-a37a-88c47b1a6908",
					"migrations_dir": "migrations"
				}
			],
			"r2_buckets": [
				{
					"binding": "BUCKET",
					"bucket_name": "baindar-assets"
				}
			],
			"ai": {
				"binding": "AI"
			},
			"send_email": [{ "name": "EMAIL" }],
			"workflows": [
				{
					"binding": "EPUB_PROCESSOR",
					"name": "baindar-epub-processor",
					"class_name": "EpubWorkflow"
				}
			],
			"durable_objects": {
				"bindings": [
					{
						"name": "ChatAgent",
						"class_name": "ChatAgent"
					},
					{
						"name": "Sandbox",
						"class_name": "Sandbox"
					}
				]
			},
			// Per-user containerised sandbox that backs the chat agent's
			// runBash tool. See the dev env above for the full rationale.
			"containers": [
				{
					"name": "baindar-sandbox-production",
					"class_name": "Sandbox",
					"image": "./Dockerfile",
					"instance_type": "lite",
					"max_instances": 1
				}
			],
			// v1 created CounterAgent (smoke test). v2 retires it and stands
			// up the real ChatAgent. v3 stands up the Sandbox container DO.
			// Migrations are append-only.
			"migrations": [
				{
					"tag": "v1",
					"new_sqlite_classes": ["CounterAgent"]
				},
				{
					"tag": "v2",
					"deleted_classes": ["CounterAgent"],
					"new_sqlite_classes": ["ChatAgent"]
				},
				{
					"tag": "v3",
					"new_sqlite_classes": ["Sandbox"]
				}
			],
			"secrets": {
				"required": [
					"BETTER_AUTH_SECRET",
					"GOOGLE_CLIENT_ID",
					"GOOGLE_CLIENT_SECRET",
					"APPLE_CLIENT_ID",
					"APPLE_CLIENT_SECRET",
					"ANTHROPIC_API_KEY",
					"CLOUDFLARE_ACCOUNT_ID",
					"R2_ACCESS_KEY_ID",
					"R2_SECRET_ACCESS_KEY"
				]
			}
		}
	}
}
