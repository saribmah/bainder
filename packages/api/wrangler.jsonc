{
	// `worker-configuration.d.ts` is generated by `bun run cf-typegen`.
	// Edit this file (not the generated d.ts), then re-run cf-typegen.
	"$schema": "node_modules/wrangler/config-schema.json",
	"compatibility_flags": ["nodejs_compat"],
	"compatibility_date": "2026-02-27",
	"name": "bainder",
	"main": "src/index.ts",
	"env": {
		"dev": {
			"name": "bainder-dev",
			"vars": {
				"API_PUBLIC_HOST": "",
				"WEB_PUBLIC_HOST": "",
				"WORKER_URL": "http://localhost:8787"
			},
			"secrets": {
				"required": ["JWT_SECRET"]
			}
			// Uncomment as needed:
			// "kv_namespaces": [{ "binding": "MY_KV", "id": "<kv-id>" }],
			// "r2_buckets": [{ "binding": "MY_BUCKET", "bucket_name": "<bucket-name>" }],
			// "d1_databases": [{ "binding": "DB", "database_name": "<db-name>", "database_id": "<db-id>" }],
			// "hyperdrive": [{ "binding": "HYPERDRIVE", "id": "<hyperdrive-id>" }]
		},
		"production": {
			"workers_dev": false,
			"routes": [
				// { "pattern": "bainder.app", "custom_domain": true },
				// { "pattern": "api.bainder.app", "custom_domain": true }
			],
			"assets": {
				// Serves the built web frontend as static assets at the root domain.
				// Delete this block if you removed packages/web during init.
				"directory": "../web/dist",
				"binding": "ASSETS",
				"not_found_handling": "single-page-application",
				"run_worker_first": true
			},
			"observability": {
				"enabled": true
			},
			"vars": {
				"API_PUBLIC_HOST": "",
				"WEB_PUBLIC_HOST": "",
				"WORKER_URL": ""
			},
			"secrets": {
				"required": ["JWT_SECRET"]
			}
		}
	}
}
