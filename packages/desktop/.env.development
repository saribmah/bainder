# Loaded by Vite when running `vite dev` (mode = "development").
# Desktop calls the API directly — no Vite proxy. The wrangler dev server's
# CORS (`origin: "*", credentials: true`) accepts http://localhost:3003.
#
# IMPORTANT: For sign-in to succeed, add http://localhost:3003 to
# TRUSTED_ORIGINS in packages/api/.env, comma-separated.
#
# Override locally in `.env.development.local` (gitignored).
VITE_API_URL=http://localhost:8787
VITE_AUTH_URL=http://localhost:8787/auth
