# Loaded by Vite when running `vite build` (mode = "production").
# Values here ship inside the bundle. Do NOT put secrets.
#
# Once you deploy the API, point both of these at it. Until then, the
# packaged .app will only work against a reachable backend you set here.
#
# For the OAuth callback to succeed, add `bainder-desktop://` to the API's
# TRUSTED_ORIGINS (set on the deployed worker).
VITE_API_URL=
VITE_AUTH_URL=
