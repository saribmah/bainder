{
  "name": "@baindar/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build:view": "bun --no-env-file run vite build",
    "build": "bunx --bun tsgo --noEmit && bun run build:view && bunx electrobun build --targets macos-arm64,macos-x64",
    "lint": "oxlint --quiet src vite.config.ts electrobun.config.ts scripts",
    "lint:fix": "oxlint --fix --quiet src vite.config.ts electrobun.config.ts scripts",
    "format": "oxfmt --check --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./scripts/**/*.{js,ts}\" \"./vite.config.ts\" \"./electrobun.config.ts\"",
    "format:fix": "oxfmt --write --no-error-on-unmatched-pattern \"./src/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"./scripts/**/*.{js,ts}\" \"./vite.config.ts\" \"./electrobun.config.ts\"",
    "ts-check": "bunx --bun tsgo --noEmit && bunx --bun tsgo --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "@baindar/sdk": "*",
    "@baindar/ui": "workspace:*",
    "better-auth": "^1.6.9",
    "electrobun": "^1.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "postcss": "^8.5.8",
    "rolldown-vite": "^7.3.1",
    "tailwindcss": "^4.2.1",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
