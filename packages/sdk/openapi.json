              "schema": {
                "$ref": "#/components/schemas/TestModeSignInInput"
              }
            }
          }
        }
      }
    },
    "/__test__/reset": {
      "post": {
        "operationId": "postTestReset",
        "summary": "[test-mode] Wipe all user data and R2 objects",
        "description": "Local-only. Gated by TEST_MODE=true. Deletes every user (FK cascades to documents, sessions, etc.) and sweeps the `users/` R2 prefix. Returns 404 in production.",
        "responses": {
          "204": {
            "description": "State wiped"
          },
          "404": {
            "description": "Test mode disabled"
          }
        }
      }
    },
