    "/__test__/status": {
      "get": {
        "operationId": "getTestStatus",
        "summary": "[test-mode] Probe whether test mode is enabled",
        "description": "Local-only. Gated by TEST_MODE=true. Returns {enabled: true} when on, 404 otherwise. Used by the @bainder/testing wrapper to skip suites when the dev server isn't running in test mode.",
        "responses": {
          "200": {
            "description": "Test mode is enabled",
            "content": {
