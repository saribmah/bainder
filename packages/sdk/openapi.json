{
  "openapi": "3.1.0",
  "info": {
    "title": "bainder API",
    "description": "bainder API OpenAPI schema",
    "version": "0.0.0"
  },
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "better-auth.session_token"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Example": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "createdAt"
        ]
      },
      "Epub": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "language": {
            "type": "string"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "publisher": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "publishedDate": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "identifiers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "subjects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "coverImage": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "chapterCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "wordCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "authors",
          "language",
          "description",
          "publisher",
          "publishedDate",
          "identifiers",
          "subjects",
          "coverImage",
          "chapterCount",
          "wordCount",
          "createdAt"
        ]
      },
      "EpubTocItem": {
        "type": "object",
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "parent": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ]
          },
          "depth": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "title": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "fileHref": {
            "type": "string"
          },
          "anchor": {
            "type": "string"
          }
        },
        "required": [
          "index",
          "parent",
          "depth",
          "title",
          "href",
          "fileHref",
          "anchor"
        ]
      },
      "EpubChapterSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bookId": {
            "type": "string"
          },
          "order": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "href": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "wordCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "linear": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "bookId",
          "order",
          "href",
          "title",
          "wordCount",
          "linear"
        ]
      },
      "EpubDetail": {
        "type": "object",
        "properties": {
          "book": {
            "$ref": "#/components/schemas/Epub"
          },
          "toc": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EpubTocItem"
            }
          },
          "chapters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EpubChapterSummary"
            }
          }
        },
        "required": [
          "book",
          "toc",
          "chapters"
        ]
      },
      "EpubChapter": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "bookId": {
            "type": "string"
          },
          "order": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "href": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "wordCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "linear": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "bookId",
          "order",
          "href",
          "title",
          "html",
          "text",
          "wordCount",
          "linear"
        ]
      },
      "EpubContext": {
        "type": "object",
        "properties": {
          "bookId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "from": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "to": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "chapterCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "wordCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "format": {
            "type": "string",
            "enum": [
              "text",
              "markdown"
            ]
          },
          "context": {
            "type": "string"
          }
        },
        "required": [
          "bookId",
          "title",
          "authors",
          "from",
          "to",
          "chapterCount",
          "wordCount",
          "format",
          "context"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "name": {
            "type": "string"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "image": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "emailVerified",
          "image",
          "createdAt",
          "updatedAt"
        ]
      }
    }
  },
  "paths": {
    "/example": {
      "get": {
        "operationId": "example.list",
        "summary": "List examples",
        "responses": {
          "200": {
            "description": "All examples",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Example"
                      }
                    }
                  },
                  "required": [
                    "items"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "example.create",
        "summary": "Create example",
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Example"
                }
              }
            }
          },
          "409": {
            "description": "Name already taken"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        }
      }
    },
    "/example/{id}": {
      "get": {
        "operationId": "example.get",
        "summary": "Get example by id",
        "responses": {
          "200": {
            "description": "Example",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Example"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ]
      }
    },
    "/epubs": {
      "post": {
        "operationId": "epub.ingest",
        "summary": "Ingest an EPUB file",
        "description": "Upload the raw EPUB bytes (Content-Type: application/epub+zip). Parses metadata, chapters, and TOC; returns book metadata.",
        "requestBody": {
          "required": true,
          "content": {
            "application/epub+zip": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Book ingested",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Epub"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or unsupported EPUB"
          },
          "401": {
            "description": "Not authenticated"
          },
          "413": {
            "description": "Upload exceeds size limit"
          },
          "422": {
            "description": "EPUB had no readable chapters"
          }
        }
      },
      "get": {
        "operationId": "epub.list",
        "summary": "List ingested EPUBs",
        "responses": {
          "200": {
            "description": "All ingested books",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Epub"
                      }
                    }
                  },
                  "required": [
                    "items"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          }
        }
      }
    },
    "/epubs/{id}": {
      "get": {
        "operationId": "epub.getDetail",
        "summary": "Get an EPUB with its TOC and chapter summaries",
        "responses": {
          "200": {
            "description": "Book detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpubDetail"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "Not found"
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ]
      },
      "delete": {
        "operationId": "epub.delete",
        "summary": "Delete an ingested EPUB",
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "Not found"
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ]
      }
    },
    "/epubs/{id}/chapters/{order}": {
      "get": {
        "operationId": "epub.getChapter",
        "summary": "Get a single chapter by linear order",
        "responses": {
          "200": {
            "description": "Chapter content (cleaned HTML and plain text)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpubChapter"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "Book or chapter not found"
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "order",
            "required": true
          }
        ]
      }
    },
    "/epubs/{id}/assets/{name}": {
      "get": {
        "operationId": "epub.getAsset",
        "summary": "Fetch a book asset (image) by name",
        "responses": {
          "200": {
            "description": "Asset bytes",
            "content": {
              "image/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "Book or asset not found"
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "name",
            "required": true
          }
        ]
      }
    },
    "/epubs/{id}/context": {
      "get": {
        "operationId": "epub.getContext",
        "summary": "Assemble AI-ready context across one or more chapters",
        "description": "Returns concatenated chapter text suitable for an LLM prompt. Default range is the entire book.",
        "responses": {
          "200": {
            "description": "Assembled context",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpubContext"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "Book or chapter range not found"
          }
        },
        "parameters": [
          {
            "in": "query",
            "name": "from",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          {
            "in": "query",
            "name": "to",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          {
            "in": "query",
            "name": "format",
            "schema": {
              "type": "string",
              "enum": [
                "text",
                "markdown"
              ]
            }
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ]
      }
    },
    "/user/me": {
      "get": {
        "operationId": "user.me",
        "summary": "Get the authenticated user",
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "User row missing"
          }
        }
      },
      "patch": {
        "operationId": "user.update",
        "summary": "Update the authenticated user's profile",
        "responses": {
          "200": {
            "description": "Updated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "User row missing"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  },
                  "image": {
                    "anyOf": [
                      {
                        "type": "string",
                        "format": "uri"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "health.get",
        "summary": "Health check",
        "description": "Check if the service is healthy.",
        "responses": {
          "200": {
            "description": "Service health status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "const": "healthy"
                    }
                  },
                  "required": [
                    "status"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
