    "/highlights": {
      "post": {
        "operationId": "highlight.create",
        "summary": "Create a highlight or note on a document",
        "description": "Creates a colour highlight (and optional note) anchored to either an EPUB chapter (`epubChapterOrder`) or a PDF page (`pdfPageNumber`). Offsets are character positions into the canonical text payload — `epub_chapter.html`'s textContent or `pdf_page.text`. Exactly one of the two target fields must be set.",
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Highlight"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or target mismatched with document kind"
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "Document not found"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "documentId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "epubChapterOrder": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "pdfPageNumber": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "offsetStart": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "offsetEnd": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "textSnippet": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 4000
                  },
                  "color": {
                    "type": "string",
                    "enum": [
                      "pink",
                      "yellow",
                      "green",
                      "blue",
                      "purple"
                    ]
                  },
                  "note": {
                    "type": "string",
                    "maxLength": 10000
                  }
                },
                "required": [
                  "documentId",
                  "offsetStart",
                  "offsetEnd",
                  "textSnippet",
                  "color"
                ]
              }
            }
          }
        }
      },
      "get": {
        "operationId": "highlight.list",
        "summary": "List highlights for a document",
        "description": "Returns highlights owned by the caller for the given `documentId`, ordered by creation time. Optional `epubChapterOrder` or `pdfPageNumber` query params scope the result to a single chapter or page.",
        "parameters": [
          {
            "name": "documentId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "epubChapterOrder",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "pdfPageNumber",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Highlights",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Highlight"
                      }
                    }
                  },
                  "required": [
                    "items"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid query"
          },
          "401": {
            "description": "Not authenticated"
          },
          "404": {
            "description": "Document not found"
          }
        }
      }
    },
    "/highlights/{id}": {
      "patch": {
        "operationId": "highlight.update",
        "summary": "Update a highlight's color or note",
        "responses": {
          "200": {
            "description": "Updated",
